<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.layout.BorderPane?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.VBox?>
<?import javafx.scene.text.Font?>

<BorderPane maxHeight="-Infinity" maxWidth="-Infinity" minHeight="600.0" minWidth="900.0" prefHeight="700.0" prefWidth="1100.0" style="-fx-background-color: #f8f9fa;" stylesheets="@style.css" xmlns="http://javafx.com/javafx/26" xmlns:fx="http://javafx.com/fxml/1" fx:controller="ui.controller.dasboardController">

   <left>
      <VBox prefWidth="260.0" style="-fx-background-color: #1a1a24;" BorderPane.alignment="CENTER">
         <children>
            <VBox alignment="CENTER_LEFT" prefHeight="80.0" spacing="5.0">
               <children>
                  <Label text="Coffe BrewSpace" textFill="WHITE">
                     <font>
                        <Font name="Segoe UI Bold" size="20.0" />
                     </font>
                  </Label>
                  <Label text="Sistem Kasir Pintar" textFill="#a0a0ab">
                     <font>
                        <Font name="Segoe UI" size="12.0" />
                     </font>
                  </Label>
               </children>
               <padding>
                  <Insets left="25.0" right="25.0" />
               </padding>
            </VBox>

            <VBox spacing="10.0" VBox.vgrow="ALWAYS">
               <children>
                  <Button fx:id="btnDataProduk" alignment="BASELINE_LEFT" maxWidth="1.7976931348623157E308" mnemonicParsing="false" onAction="#openDataProduk" prefHeight="45.0" style="-fx-background-color: transparent; -fx-text-fill: #e2e2e7; -fx-font-size: 14px; -fx-cursor: hand; -fx-alignment: center_left; -fx-padding: 0 20;" text="📦   Data Produk">
                     <font>
                        <Font name="Segoe UI Semibold" size="14.0" />
                     </font>
                  </Button>
                  <Button fx:id="btnDataUser" alignment="BASELINE_LEFT" maxWidth="1.7976931348623157E308" mnemonicParsing="false" onAction="#openUser" prefHeight="45.0" style="-fx-background-color: transparent; -fx-text-fill: #e2e2e7; -fx-font-size: 14px; -fx-cursor: hand; -fx-alignment: center_left; -fx-padding: 0 20;" text="👥   Data User">
                     <font>
                        <Font name="Segoe UI Semibold" size="14.0" />
                     </font>
                  </Button>
                  <Button alignment="BASELINE_LEFT" maxWidth="1.7976931348623157E308" mnemonicParsing="false" onAction="#openTransaksi" prefHeight="45.0" style="-fx-background-color: transparent; -fx-text-fill: #e2e2e7; -fx-font-size: 14px; -fx-cursor: hand; -fx-alignment: center_left; -fx-padding: 0 20;" text="🛒   Transaksi">
                     <font>
                        <Font name="Segoe UI Semibold" size="14.0" />
                     </font>
                  </Button>
                  <Button alignment="BASELINE_LEFT" maxWidth="1.7976931348623157E308" mnemonicParsing="false" onAction="#openRiwayat" prefHeight="45.0" style="-fx-background-color: transparent; -fx-text-fill: #e2e2e7; -fx-font-size: 14px; -fx-cursor: hand; -fx-alignment: center_left; -fx-padding: 0 20;" text="📜   Riwayat">
                     <font>
                        <Font name="Segoe UI Semibold" size="14.0" />
                     </font>
                  </Button>
               </children>
               <padding>
                  <Insets top="20.0" />
               </padding>
            </VBox>

            <VBox alignment="BOTTOM_CENTER" prefHeight="80.0">
               <children>
                  <Button maxWidth="1.7976931348623157E308" mnemonicParsing="false" onAction="#logout" prefHeight="45.0" style="-fx-background-color: #e74c3c; -fx-text-fill: white; -fx-font-weight: bold; -fx-background-radius: 8px; -fx-cursor: hand;" text="🚪  Logout">
                     <font>
                        <Font name="Segoe UI Bold" size="14.0" />
                     </font>
                  </Button>
               </children>
               <padding>
                  <Insets bottom="20.0" left="20.0" right="20.0" />
               </padding>
            </VBox>
         </children>
      </VBox>
   </left>

   <center>
      <VBox spacing="30.0" BorderPane.alignment="CENTER">
         <padding>
            <Insets bottom="40.0" left="40.0" right="40.0" top="30.0" />
         </padding>
         <children>

            <HBox alignment="CENTER_LEFT" prefHeight="60.0" style="-fx-background-color: #ffffff; -fx-background-radius: 12px; -fx-effect: dropshadow(three-pass-box, rgba(0,0,0,0.05), 10, 0, 0, 4);">
               <children>
                  <VBox alignment="CENTER_LEFT" HBox.hgrow="ALWAYS">
                     <children>
                        <Label text="Utama > Dashboard" textFill="#a0a0ab">
                           <font>
                              <Font name="Segoe UI" size="12.0" />
                           </font>
                        </Label>
                        <Label text="Kasir Coffe Brewspace" textFill="#1a1a24">
                           <font>
                              <Font name="Segoe UI Bold" size="20.0" />
                           </font>
                        </Label>
                     </children>
                  </VBox>
                  <HBox alignment="CENTER_RIGHT" spacing="15.0">
                     <children>
                        <Label fx:id="welcomeUsername" text="Halo, Kasir!" textFill="#57606f">
                           <font>
                              <Font name="Segoe UI Semibold" size="14.0" />
                           </font>
                        </Label>
                        <Button fx:id="btnEditProfile" mnemonicParsing="false" onAction="#openEditProfile" prefHeight="35.0" style="-fx-background-color: #c47b4d; -fx-text-fill: white; -fx-background-radius: 6px; -fx-cursor: hand; -fx-font-weight: bold;" text="✏️ Edit Profile">
                           <padding>
                              <Insets left="15.0" right="15.0" />
                           </padding>
                        </Button>
                     </children>
                  </HBox>
               </children>
               <padding>
                  <Insets left="20.0" right="20.0" />
               </padding>
            </HBox>

            <VBox alignment="CENTER" style="-fx-background-color: #ffffff; -fx-background-radius: 12px; -fx-border-color: #e2e2e7; -fx-border-width: 1px; -fx-border-radius: 12px;" VBox.vgrow="ALWAYS">
               <children>
                  <Label text="Selamat Datang di Dashboard Coffe BrewSpace" textFill="#718093">
                     <font>
                        <Font name="Segoe UI Bold" size="18.0" />
                     </font>
                  </Label>
                  <Label text="Silakan pilih menu di sebelah kiri untuk mengelola data." textFill="#a0a0ab">
                     <font>
                        <Font name="Segoe UI" size="14.0" />
                     </font>
                     <VBox.margin>
                        <Insets top="5.0" />
                     </VBox.margin>
                  </Label>
               </children>
            </VBox>

         </children>
      </VBox>
   </center>
</BorderPane>