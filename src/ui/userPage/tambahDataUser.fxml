<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.RadioButton?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.layout.AnchorPane?>
<?import javafx.scene.text.Font?>

<?import javafx.scene.control.ToggleGroup?>
<AnchorPane prefHeight="400.0" prefWidth="600.0" xmlns="http://javafx.com/javafx/26" xmlns:fx="http://javafx.com/fxml/1" fx:controller="ui.controller.userController">
    <fx:define>
        <ToggleGroup fx:id="levelGroup"/>
    </fx:define>
    <children>
        <Label layoutX="177.0" layoutY="149.0" prefHeight="22.0" prefWidth="242.0" text="Username">
            <font>
                <Font size="15.0" />
            </font>
        </Label>
        <TextField fx:id="txtUsername" layoutX="176.0" layoutY="171.0" prefHeight="26.0" prefWidth="242.0" />
        <Label layoutX="22.0" layoutY="14.0" prefHeight="30.0" prefWidth="554.0" text="Kasir Coffe Brewspace">
            <font>
                <Font size="24.0" />
            </font>
        </Label>
        <Label alignment="CENTER" contentDisplay="CENTER" layoutX="21.0" layoutY="49.0" prefHeight="30.0" prefWidth="554.0" text="Tambah Data User" textAlignment="CENTER">
            <font>
                <Font size="24.0" />
            </font>
        </Label>
        <Label layoutX="178.0" layoutY="203.0" prefHeight="22.0" prefWidth="242.0" text="Password">
            <font>
                <Font size="15.0" />
            </font>
        </Label>
        <TextField fx:id="txtPassword" layoutX="176.0" layoutY="225.0" prefHeight="26.0" prefWidth="242.0" />
        <Button layoutX="178.0" layoutY="295.0" mnemonicParsing="false" onAction="#submitUser" prefHeight="26.0" prefWidth="242.0" text="Tambah User" />
        <Button layoutX="22.0" layoutY="54.0" mnemonicParsing="false" onAction="#backBtnToDataUser" text="kembali" />
      <RadioButton fx:id="admin" toggleGroup="$levelGroup" layoutX="178.0" layoutY="267.0" mnemonicParsing="false" text="Admin" />
      <RadioButton fx:id="kasir" toggleGroup="$levelGroup" layoutX="249.0" layoutY="267.0" mnemonicParsing="false" text="Kasir" />
    </children>

</AnchorPane>
